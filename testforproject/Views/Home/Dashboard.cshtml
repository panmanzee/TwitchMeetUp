@model IEnumerable<testforproject.Models.Event>

@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/Home/dashboard.css">
<div class="dashboard-body">
    <header class="top-bar">
        <div style="font-size: 24px;">☰</div>
        <div class="search-container">
            <input type="text" placeholder="Search activities...">
        </div>
        <div class="auth-buttons">
            <a href="@Url.Action("CreateActivity", "Home")" style="background: #ff4d4d; padding: 10px 20px; border-radius: 20px;">+ Create Activity</a>
            <a href="#">Login</a>
        </div>
    </header>

    <section class="category-row">
        <div class="cat-card">Category 1</div>
        <div class="cat-card active">Category 2</div>
        <div class="cat-card">Category 3</div>
    </section>

    <nav class="filter-nav">
        <button class="filter-btn active">Recommended</button>
        <button class="filter-btn">Participant</button>
        <button class="filter-btn">Recent</button>
    </nav>

    <section class="event-grid" id="eventGrid">
        @if (Model != null)
        {
            @foreach (var item in Model)
            {
                
                <div class="event-card" id="event-card-@item.Eid">

                    <div class="card-img">Image Placeholder</div>
                    <div class="card-content">
                        <h4>@item.Name</h4>
                        <p>👤 Owner: @item.Owner.Email</p>
                        <p>📍 @item.Location</p>

                        <div class="card-footer">
                            <span style="font-size: 13px;">🎯 Target: @item.MaxParticitpant</span>
                            
                        </div>
                    </div>
                </div>
            }
        }
    </section>
    <div class="text-center mt-5 mb-5" id="viewMoreContainer">
        <button class="btn-view-more" onclick="loadMore()">View More</button>
    </div>
    <script src="~/js/Home/loadmore.js"></script>
</div>

