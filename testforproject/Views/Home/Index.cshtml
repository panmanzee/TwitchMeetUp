@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Event Time — Find People for Every Activity</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>

    <!-- Floating Particles -->
    <div class="particles" id="particles"></div>

    <!-- ====================================================
         NAVBAR
         ==================================================== -->
    <nav class="lp-nav" id="lp-nav">
        <div class="lp-nav-inner">
            <a href="/" class="lp-brand">
                <div class="lp-brand-wrapper">
                    <img src="/images/brainnotnormalRabbits.png" class="lp-brand-img" alt="EventTime Logo" />
                    <span class="lp-brand-text">Event <span class="lp-brand-accent">Time</span></span>
                </div>
            </a>

            <div class="lp-nav-links">
                <a href="#features" class="lp-nav-link">Features</a>
                <a href="#how-it-works" class="lp-nav-link">How it Works</a>
            </div>

            <div class="lp-nav-actions">
                <a href="/Account/Login" class="lp-btn-ghost">Log In</a>
                <a href="/Account/Register" class="lp-btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- ====================================================
         HERO
         ==================================================== -->
    <section class="lp-hero">
        <div class="hero-glow-top"></div>
        <div class="hero-glow-bottom"></div>

        <div class="lp-hero-inner">

            <!-- Left: Content -->
            <div class="lp-hero-content">
                <div class="lp-hero-badge">
                    <span class="badge-pulse"></span>
                    Find your activity partner today
                </div>

                <h1 class="lp-hero-title">
                    Find People,<br>
                    Do Things <span class="lp-gradient-text">Together</span>
                </h1>

                <p class="lp-hero-sub">
                    Browse events and activities around you — or create your own. From sports and food tours to workshops and outdoor trips, connect with people who share your vibe.
                </p>

                <div class="lp-hero-actions">
                    <a href="/Account/Register" class="lp-cta-primary">
                        Get Started
                        <i class="fas fa-arrow-right"></i>
                    </a>
                    <a href="/Account/Login" class="lp-cta-secondary">
                        <i class="fas fa-sign-in-alt"></i>
                        Log In
                    </a>
                </div>

                <div class="lp-hero-stats">
                    <div class="lp-stat">
                        <span class="lp-stat-num">Create</span>
                        <span class="lp-stat-lbl">Your own events</span>
                    </div>
                    <div class="lp-stat-sep"></div>
                    <div class="lp-stat">
                        <span class="lp-stat-num">Join</span>
                        <span class="lp-stat-lbl">Others' events</span>
                    </div>
                    <div class="lp-stat-sep"></div>
                    <div class="lp-stat">
                        <span class="lp-stat-num">Meet</span>
                        <span class="lp-stat-lbl">New people</span>
                    </div>
                </div>
            </div>

            <!-- Right: App Preview -->
            <div class="lp-hero-visual">
                <div class="lp-app-preview">
                    <div class="lp-app-header">
                        <span class="lp-app-title"><i class="fas fa-compass"></i> Discover Events</span>
                        <div class="lp-app-cats">
                            <span class="lp-cat lp-cat-active">All</span>
                            <span class="lp-cat">Sports</span>
                            <span class="lp-cat">Food</span>
                            <span class="lp-cat">Arts</span>
                        </div>
                    </div>

                    <div class="lp-app-events">
                        <div class="lp-app-event">
                            <div class="lp-app-event-dot dot-sports"></div>
                            <div class="lp-app-event-info">
                                <span class="lp-app-event-name">Morning Yoga at the Park</span>
                                <span class="lp-app-event-meta">
                                    <i class="fas fa-users"></i> 8 / 20 joined &nbsp;
                                    <i class="fas fa-tag"></i> Sports
                                </span>
                            </div>
                            <span class="lp-app-join-btn">Join</span>
                        </div>

                        <div class="lp-app-event">
                            <div class="lp-app-event-dot dot-food"></div>
                            <div class="lp-app-event-info">
                                <span class="lp-app-event-name">Street Food Tour — Old Town</span>
                                <span class="lp-app-event-meta">
                                    <i class="fas fa-users"></i> 12 / 15 joined &nbsp;
                                    <i class="fas fa-tag"></i> Food
                                </span>
                            </div>
                            <span class="lp-app-join-btn">Join</span>
                        </div>

                        <div class="lp-app-event">
                            <div class="lp-app-event-dot dot-arts"></div>
                            <div class="lp-app-event-info">
                                <span class="lp-app-event-name">Photography Walk Downtown</span>
                                <span class="lp-app-event-meta">
                                    <i class="fas fa-users"></i> 5 / 10 joined &nbsp;
                                    <i class="fas fa-tag"></i> Arts
                                </span>
                            </div>
                            <span class="lp-app-join-btn">Join</span>
                        </div>
                    </div>

                    <div class="lp-app-bottom">
                        <div class="lp-app-qr">
                            <i class="fas fa-qrcode"></i>
                            <span>QR Check-in</span>
                        </div>
                        <div class="lp-app-chat">
                            <i class="fas fa-comments"></i>
                            <span>Event Chat</span>
                        </div>
                        <div class="lp-app-rating">
                            <i class="fas fa-star"></i>
                            <span>Rate & Review</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- ====================================================
         FEATURES
         ==================================================== -->
    <section class="lp-features" id="features">
        <div class="lp-section-inner">
            <div class="lp-section-label">What You Can Do</div>
            <h2 class="lp-section-title">
                Everything in one place to<br>
                <span class="lp-gradient-text">plan and enjoy activities</span>
            </h2>

            <div class="lp-features-grid">
                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-plus-circle"></i>
                    </div>
                    <h3>Create Events</h3>
                    <p>Host your own event in minutes. Set the date, location, capacity, and category — then invite others to join.</p>
                </div>

                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-search"></i>
                    </div>
                    <h3>Browse & Join</h3>
                    <p>Explore events by category, date, or location. Find something that fits your schedule and tap to join instantly.</p>
                </div>

                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-th-large"></i>
                    </div>
                    <h3>Event Categories</h3>
                    <p>Filter events by category — sports, food, arts, outdoor, music, workshops, and more. Something for every interest.</p>
                </div>

                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-qrcode"></i>
                    </div>
                    <h3>QR Check-in</h3>
                    <p>When event day arrives, scan the QR code at the venue to check in. No paper, no hassle — just show up and scan.</p>
                </div>

                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h3>Event Chat</h3>
                    <p>Talk with fellow participants right inside the event page. Coordinate meetup spots, ask questions, and get to know each other before the day.</p>
                </div>

                <div class="lp-feat-card">
                    <div class="lp-feat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>Ratings & Follow</h3>
                    <p>Rate events after attending and follow your favourite organisers to get notified when they post something new.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================================================
         HOW IT WORKS
         ==================================================== -->
    <section class="lp-hiw" id="how-it-works">
        <div class="lp-section-inner">
            <div class="lp-section-label">Simple Process</div>
            <h2 class="lp-section-title">
                Getting started<br>
                <span class="lp-gradient-text">takes 3 steps</span>
            </h2>

            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-num">01</div>
                    <div class="lp-step-content">
                        <h3>Register an Account</h3>
                        <p>Sign up for free and set up your profile. Pick the activity categories you enjoy so we can show you relevant events.</p>
                    </div>
                </div>

                <div class="lp-step-arrow">
                    <i class="fas fa-chevron-right"></i>
                </div>

                <div class="lp-step">
                    <div class="lp-step-num">02</div>
                    <div class="lp-step-content">
                        <h3>Find or Create an Event</h3>
                        <p>Browse events by category and join one that interests you — or create your own event and let others come to you.</p>
                    </div>
                </div>

                <div class="lp-step-arrow">
                    <i class="fas fa-chevron-right"></i>
                </div>

                <div class="lp-step">
                    <div class="lp-step-num">03</div>
                    <div class="lp-step-content">
                        <h3>Show Up &amp; Check In</h3>
                        <p>Chat with participants beforehand, arrive at the event, scan the QR code to check in, and enjoy the activity together.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================================================
         CTA BANNER
         ==================================================== -->
    <section class="lp-cta-section">
        <div class="lp-cta-glow"></div>
        <div class="lp-section-inner lp-cta-inner">
            <h2 class="lp-cta-title">Ready to find your people?</h2>
            <p class="lp-cta-sub">
                Create an account, pick what you love, and start joining or hosting events with people in your area.
            </p>
            <a href="/Account/Register" class="lp-cta-primary lp-cta-big">
                Create Your Free Account
                <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </section>

    <!-- ====================================================
         FOOTER
         ==================================================== -->
    <footer class="lp-footer">
        <div class="lp-footer-inner">
            <a href="/" class="lp-brand lp-footer-brand">
                <div class="lp-brand-wrapper">
                    <img src="/images/brainnotnormalRabbits.png" class="lp-brand-img" alt="EventTime Logo" />
                    <span class="lp-brand-text">Event <span class="lp-brand-accent">Time</span></span>
                </div>
            </a>

            <p class="lp-footer-copy">&copy; 2025 Event Time. All rights reserved.</p>

            <div class="lp-footer-links">
                <a href="/Account/Login">Log In</a>
                <a href="/Account/Register">Register</a>
            </div>
        </div>
    </footer>

    <script>
        // Generate floating particles
        const container = document.getElementById('particles');
        for (let i = 0; i < 35; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            const size = Math.random() * 3 + 1;
            p.style.cssText = [
                'width:' + size + 'px',
                'height:' + size + 'px',
                'left:' + (Math.random() * 100) + '%',
                'animation-duration:' + (Math.random() * 18 + 12) + 's',
                'animation-delay:' + (Math.random() * 18) + 's',
                'opacity:' + (Math.random() * 0.3 + 0.05)
            ].join(';');
            container.appendChild(p);
        }

        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            document.getElementById('lp-nav').classList.toggle('lp-nav-scrolled', window.scrollY > 30);
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(function (a) {
            a.addEventListener('click', function (e) {
                e.preventDefault();
                var target = document.querySelector(a.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>

</body>
</html>
