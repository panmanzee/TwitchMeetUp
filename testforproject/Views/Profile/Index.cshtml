@model testforproject.Models.User
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Creator Profile</title>
    <link rel="stylesheet" href="~/css/Profile/MyProfile.css">
</head>

<body>
    <div class="container">
        <div class="header" style="position: relative;">
            <a href="@Url.Action("Show", "Dashboard")"
                style="position: absolute; left: 0; top: 0; color: #9146FF; text-decoration: none; font-weight: bold;">&larr;
                Back to Dashboard</a>
            <h2>My Profile</h2>
            @if (Model.Username == ViewBag.user)
            {
                <a href="@Url.Action("edit", "profile")"
                    style="background: #ff4d4d; padding: 10px 20px; border-radius: 20px;">Edit Profile</a>
            }
        </div>
        <div class="banner"></div>
        <div class="content">
            <div class="sidebar">
                <div class="profile-avatar">
                    @if (Model.ProfilePictureSrc == null)
                    {
                        <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png" />
                    }
                    else
                    {
                        <img asp-append-version="true" src="~/imageProfile/@(Model.Uid + ".jpg")" />
                    }
                </div>
                <h3>@Model.Username</h3>
                <p class="followers">
                    <span id="followerCount">@ViewBag.FollowerCount</span> followers
                </p>

                @if (Model.Username != ViewBag.user)
                {
                    @if (ViewBag.user == null)
                    {
                        <a href="/" class="follow-btn">Follow</a>
                    }
                    else
                    {
                        <button id="followBtn" class="follow-btn @(ViewBag.IsFollowing ? "unfollow" : "")"
                            data-user-id="@Model.Uid" data-following="@ViewBag.IsFollowing.ToString().ToLower()">
                            @(ViewBag.IsFollowing ? "Unfollow" : "Follow")
                        </button>
                    }
                }
            </div>
            <div class="main">
                <div class="bio">
                    <h3>About Me</h3>
                    <p>
                        @(string.IsNullOrWhiteSpace(Model.Bio) ? "No bio provided." : Model.Bio)
                    </p>
                </div>
                <div class="section">
                    <h3>Participated Event</h3>
                    <div class="cards">
                        @if (Model.ParticipatedEvent != null && Model.ParticipatedEvent.Any())
                        {
                            @foreach (var ev in Model.ParticipatedEvent)
                            {
                                <div class="event-card">
                                    <a href="@Url.Action("EventDetails", "Event", new { id = ev.Eid })"
                                        style="text-decoration: none; color: inherit; display: block;">
                                        @if (!string.IsNullOrEmpty(ev.ImageUrl))
                                        {
                                            <div class="event-card-img" style="background-image:url('@ev.ImageUrl')"></div>
                                        }
                                        else
                                        {
                                            <div class="event-card-img no-img">📅</div>
                                        }
                                        <div class="event-card-body">
                                            <div class="event-card-name">@ev.Name</div>
                                            <div class="event-card-location">📍 @ev.Location</div>
                                        </div>
                                    </a>
                                    @if (Model.Username == ViewBag.user)
                                    {
                                        <div class="event-card-footer">
                                            @if (ev.EventStop < DateTime.Now)
                                            {
                                                <button class="event-unjoin-btn"
                                                    style="background-color: #ff9900; color: white; border: none;"
                                                    onclick="alert('ระบบให้คะแนนกำลังอยู่ในระหว่างการพัฒนา')">Give Score</button>
                                            }
                                            else if (ev.IsExpired || ev.status == "closed")
                                            {
                                                <button disabled class="event-unjoin-btn"
                                                    style="background-color: #555; color: #ccc; cursor: not-allowed; border: none;">Locked</button>
                                            }
                                            else
                                            {
                                                <button onclick="unjoinEvent(@ev.Eid, this)" class="event-unjoin-btn">Unjoin</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-text">No participated events yet.</p>
                        }
                    </div>
                </div>

                <div class="section">
                    <h3>My Event</h3>
                    <div class="cards">
                        @if (Model.OwningEvent != null && Model.OwningEvent.Any())
                        {
                            @foreach (var ev in Model.OwningEvent)
                            {
                                <div class="event-card">
                                    <a href="@Url.Action("EventDetails", "Event", new { id = ev.Eid })"
                                        style="text-decoration: none; color: inherit; display: block;">
                                        @if (!string.IsNullOrEmpty(ev.ImageUrl))
                                        {
                                            <div class="event-card-img" style="background-image:url('@ev.ImageUrl')"></div>
                                        }
                                        else
                                        {
                                            <div class="event-card-img no-img">📅</div>
                                        }
                                        <div class="event-card-body">
                                            <div class="event-card-name">@ev.Name</div>
                                            <div class="event-card-location">📍 @ev.Location</div>
                                        </div>
                                    </a>
                                    <div class="event-card-footer">
                                        <a asp-controller="Event" asp-action="ManageEvent" asp-route-id="@ev.Eid"
                                            class="event-edit-btn">Edit</a>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-text">No events created yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/Profile/MyProfile.js"></script>
</body>

</html>