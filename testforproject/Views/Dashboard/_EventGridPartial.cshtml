@model IEnumerable<testforproject.Models.Event>

@if (Model != null)
{
    @foreach (var i in Model)
    {
        <div class="event-card premium-card" onclick="window.location.href='@Url.Action("EventDetails", "Event", new { id = i.Eid })'" id="event-card-@i.Eid">

            <div class="card-image-wrapper">
                @if (!string.IsNullOrEmpty(i.ImageUrl))
                {
                    <img src="@i.ImageUrl" alt="@i.Name" class="card-img" />
                }
                else
                {
                    <div class="card-no-img">No Image</div>
                }

                @if (i.IsExpired || i.EventStop < DateTime.Now || i.status == "closed")
                {
                    <span class="status-badge badge-closed">Closed</span>
                }
                else
                {
                    <span class="status-badge badge-open">@i.status</span>
                }
            </div>

            <div class="card-body">
                <h4 class="card-title" title="@i.Name">@i.Name</h4>

                <div class="card-info-grid">
                    <p title="Owner"><span class="icon">👤</span> @(i.Owner != null ? i.Owner.Username : "Unknown")</p>
                    <p title="Location"><span class="icon">📍</span> @i.Location</p>
                    <p title="Open"><span class="icon">🟢</span> @i.EventStart.ToString("dd/MM/yy HH:mm")</p>
                    <p title="Close"><span class="icon">🔴</span> @i.EventStop.ToString("dd/MM/yy HH:mm")</p>
                </div>
            </div>

            <div class="card-footer-premium">
                <div class="target-box">
                    <span class="icon">🎯</span> Target: <strong>@i.MaxParticitpant</strong>
                </div>

                @* <div class="card-actions">
                    @if (i.IsExpired || i.EventStop < DateTime.Now || i.status == "closed")
                    {
                        <button class="btn-ended" disabled>Ended</button>
                    }
                    else
                    {
                        <button class="btn-join" onclick="window.location.href='@Url.Action("EventDetails", "Event", new { id = i.Eid })'">Join</button>
                    }
                </div> *@
            </div>
        </div>
    }
}


