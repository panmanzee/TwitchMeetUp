@model IEnumerable<testforproject.Models.Event>

@{
    ViewData["Title"] = "Dashboard";
}



<link rel="stylesheet" href="~/css/Notification/Noti.css">
<link rel="stylesheet" href="~/css/Dashboard/Dashboard2.css">
<link rel="stylesheet" href="~/css/Notification/Noti.css">

<div class="container">
    <div class="head">
        <!-- Kept the hamburger and search bar -->
        <div class="search" style="margin-left: 0;">
            <div style="position: relative;">
                <div class="hamburger" onclick="toggleSortMenu()">☰</div>

                <div id="sortMenu" class="sort-dropdown" style="display: none; position: absolute; top: 100%; left: 0; background: #18181b; border: 1px solid #303032; border-radius: 8px; z-index: 100; padding: 10px; min-width: 180px; margin-top: 15px;">
                    <p style="margin: 0 0 10px 0; font-size: 12px; color: #adadb8;">SORT BY</p>
                    <div class="sort-option @(ViewBag.SortOrder == "" ? "active" : "")" onclick="applySort('')">Newest First</div>
                    <div class="sort-option @(ViewBag.SortOrder == "name_asc" ? "active" : "")" onclick="applySort('name_asc')">Name (A-Z)</div>
                    <div class="sort-option @(ViewBag.SortOrder == "name_desc" ? "active" : "")" onclick="applySort('name_desc')">Name (Z-A)</div>
                </div>
            </div>

            <div class="search-container-bar" style="position: relative;">
                <form id="searchForm" method="get" asp-controller="Dashboard" asp-action="Show" style="display: flex;">
                    <input type="text" id="search-group" name="searchQuery" value="@ViewBag.SearchQuery" placeholder="Search activities or categories..." />
                    <div id="complete" class="complete-items"></div>
                    <input type="hidden" id="sortOrderInput" name="sortorder" value="@ViewBag.SortOrder" />
                    <input type="hidden" id="categoryInput" name="CategoryFilter" value="@ViewBag.CategoryFilter" />
                    <button type="submit" style="display: none;">Search</button>
                </form>
            </div>
        </div>
        
        <div class="auth-buttons" style="display: flex; align-items: center; gap: 10px;">
            @if (ViewBag.IsLoggedIn == true)
            {
                <!-- Notification Bell & Panel -->
                <div class="noti-btn-container" style="position: relative; display: inline-block;">
                    <button class="bell-btn" id="bellBtn" aria-label="Notifications" style="width: 40px; height: 40px; background: #18181b; border: 1px solid #303032; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#9146FF';" onmouseout="this.style.borderColor='#303032';" title="Notification">
                        <svg viewBox="0 0 24 24" fill="currentColor" style="width: 20px; height: 20px; color: #efeff1;">
                            <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" />
                        </svg>
                        <span class="badge" id="badgeCount" style="display: none;"></span>
                    </button>
                    <!-- Notification Panel -->
                    <div class="noti-panel" id="notiPanel" role="dialog" aria-label="Notifications" style="right: 0; top: 55px;">
                        <div class="panel-header">
                            <h2>การแจ้งเตือน</h2>
                            <button class="settings-btn" title="Notification settings">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81 c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29 L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58 C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32 c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84 c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32 c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                                </svg>
                            </button>
                        </div>
                        <div class="noti-list" id="notiList"></div>
                    </div>
                </div>
                <!-- Profile Dropdown -->
                <div class="profile-btn-container" style="position: relative; display: inline-block;">
                    <button id="profileDropdownBtn" onclick="document.getElementById('profileDropdown').style.display = document.getElementById('profileDropdown').style.display === 'block' ? 'none' : 'block';" style="width: 40px; height: 40px; background: #9146FF; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; color: white; border: 2px solid #303032; padding: 0; overflow: hidden; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#9146FF';" onmouseout="this.style.borderColor='#303032';">
                        @if (ViewBag.ProfilePic != null)
                        {
                            <img src="~/imageProfile/@(ViewBag.Uid + ".jpg")" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            @(((string)ViewBag.Username ?? "U").Substring(0, 1).ToUpper())
                        }
                    </button>
                    
                    <div id="profileDropdown" class="profile-dropdown-content" style="display: none; position: absolute; right: 0; top: 55px; background: #18181b; border: 1px solid #303032; border-radius: 12px; width: 250px; z-index: 1000; box-shadow: 0 4px 20px rgba(0,0,0,0.8); overflow: hidden;">
                        <div style="padding: 10px 0;">
                            <a href="@Url.Action("Index", "Profile")" style="display: flex; align-items: center; gap: 15px; padding: 12px 20px; color: #efeff1; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#303032';" onmouseout="this.style.background='transparent';">
                                <span style="font-size: 8px;">👤</span> My Profile
                            </a>
                            <a href="@Url.Action("Create", "CreateActivity")" style="display: flex; align-items: center; gap: 15px; padding: 12px 20px; color: #efeff1; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#303032';" onmouseout="this.style.background='transparent';">
                                <span style="font-size: 8px;">➕</span> Create Event
                            </a>

                            <a href="@Url.Action("Onboarding", "Account")" style="display: flex; align-items: center; gap: 15px; padding: 12px 20px; color: #efeff1; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#303032';" onmouseout="this.style.background='transparent';">
                                <span style="font-size: 8px;">✨</span> Edit Preference
                            </a>
                            <hr style="border: 0; border-top: 1px solid #303032; margin: 5px 0;" />
                            <a href="@Url.Action("Logout", "Account")" style="display: flex; align-items: center; gap: 15px; padding: 12px 20px; color: #ff4d4d; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#303032';" onmouseout="this.style.background='transparent';">
                                <span style="font-size: 8px;">🚪</span> Logout
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <a href="@Url.Action("Login", "Account")" style="background: transparent; border: 1px solid #9146FF; padding: 10px 20px; border-radius: 20px; color: #efeff1; text-decoration: none;">Login</a>
                <a href="@Url.Action("Register", "Account")" style="background: #303032; padding: 10px 20px; border-radius: 20px; color: #efeff1; text-decoration: none;">Register</a>
            }
        </div>
    </div>


    <div class="category">
        <button class="slide" onclick="slide('left')">&#10094;</button>
        <div class="category-slide" id="categorylist">
            @{
                bool isActiveAll = false;

                if (string.IsNullOrEmpty(ViewBag.CategoryFilter))
                {
                    isActiveAll = true;
                }
            }

            @if (isActiveAll)
            {
                <div class="option active" onclick="selectCategory('', this)">
                    <span>All Activities</span>
                </div>
            }
            else
            {
                <div class="option" onclick="selectCategory('', this)">
                    <span>All Activities</span>
                </div>
            }
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    bool isActive = false;

                    if (ViewBag.CategoryFilter != null)
                    {
                        if (ViewBag.CategoryFilter.ToString() == cat.Name.ToString())
                        {
                            isActive = true;
                        }
                    }

                    if (isActive)
                    {
                        <div class="option active" onclick="selectCategory('@cat.Name', this)">
                            <img src="@cat.ImageUrl" class="cat-img" alt="@cat.Name" />
                            <span>@cat.Name</span>
                        </div>
                    }
                    else
                    {
                        <div class="option" onclick="selectCategory('@cat.Name', this)">
                            <img src="@cat.ImageUrl" class="cat-img" alt="@cat.Name" />
                            <span>@cat.Name</span>
                        </div>
                    }
                }
            }
        </div>
        <button class="slide" onclick="slide('right')">&#10095;</button>
    </div>

    <div class="navi">
        <div class="navigaor">Recommend</div>
        
    </div>
    <div class="scroll-container">
        @if (ViewBag.RecommendedEvents != null)
        {
            foreach (var rec in (List<testforproject.Services.RecommendationScoreResult>)ViewBag.RecommendedEvents)
            {
                <div class="activity rec-card" onclick="window.location.href='/Event/EventDetails?id=@rec.Event.Eid'">
                    @if (!string.IsNullOrEmpty(rec.Event.ImageUrl))
                    {
                        <img class="rec-img" src="@rec.Event.ImageUrl" alt="@rec.Event.Name" />
                    }
                    else
                    {
                        <div class="rec-no-img">No Image</div>
                    }
                    <div class="rec-info">
                        <h4>@rec.Event.Name</h4>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="activity">No activities found.</div>
        }
    </div>

    <section class="event-grid" id="eventGridContainer">
        <partial name="_EventGridPartial" model="Model" />
    </section>
    <div class="loadmore" id="viewMore">
        <button class="btn-view-more" onclick="loadMore()">View More</button>
    </div>

    <script src="~/js/Home/loadmore.js"></script>
    <script src="~/js/Home/dashboard.js"></script>
    <script src="~/js/Notification/Noti.js"></script>
</div>
