@model testforproject.Models.Event
@{
    var now = DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(7));
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>@Model.Name - TwitchMeet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Event/EventDetails.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>

<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <a href="/" class="nav-logo">
            <div class="logo-wrapper">
                <img src="/images/brainnotnormalRabbits.png" class="logo-img" alt="EventTime Logo" />
                <span class="logo-text">Event<span>Time</span></span>
            </div>
        </a>

        <div class="nav-links">
            <a href="/" class="active">Home</a>
            @* <a href="#">Idk</a> *@
            <a href="@Url.Action("Index", "Profile")">My Events</a>
        </div>

        <div class="nav-right">
            <button class="nav-hamburger" id="navHamburger" aria-label="Menu">&#9776;</button>
            @if (ViewBag.IsLoggedIn == true)
            {
                <div class="nav-profile">
                    <img src="@(!string.IsNullOrEmpty(ViewBag.ProfilePic)
                                                     ? ViewBag.ProfilePic
                                                    : "https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg")"
                         onerror="this.src='https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg'" />
                    <span class="username">@ViewBag.Username</span>
                    <span class="chevron">▼</span>
                    <div class="profile-dropdown">
                        <a href="@Url.Action("Index", "Profile")">My Profile</a>
                        <a href="@Url.Action("Create", "CreateActivity")">Create Event</a>
                        @if (Model.Owner?.Uid == ViewBag.UserId)
                        {
                            <a asp-controller="Event" asp-action="ManageEvent" asp-route-id="@Model.Eid">Manage Event</a>
                        }
                        <div class="divider"></div>
                        <a href="#" class="logout" onclick="logout()">Logout</a>
                    </div>
                </div>
            }
            else
            {
                <a href="@Url.Action("Register", "Account")">
                    <button class="btn-register">Register</button>
                </a>
                <a href="@Url.Action("Login", "Account")">
                    <button class="btn-login">Login</button>
                </a>
            }
        </div>
    </nav>

    <!-- ===== HERO ===== -->
    <div class="event-hero">
        <div class="hero-bg-image"
             style="background-image: url('@(!string.IsNullOrEmpty(Model.ImageUrl)
                      ? Model.ImageUrl
                      : Model.Categories?.FirstOrDefault()?.ImageUrl
                        ?? "https://images.unsplash.com/photo-1542751371-adc38448a05e?w=1600")')">
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-purple-glow"></div>
        <div class="hero-grid"></div>
        <div class="hero-content">
            <div class="hero-categories">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    foreach (var cat in Model.Categories)
                    {
                        <div class="hero-cat-tag">@cat.Name</div>
                    }
                }
            </div>
            <h1 class="hero-title">@Model.Name</h1>
            <div class="hero-meta">
                <div class="hero-host">
                    <img src="@(!string.IsNullOrEmpty(Model.Owner?.ProfilePictureSrc)
                                                     ? Model.Owner.ProfilePictureSrc
                                                    : "https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg")"
                         onerror="this.src='https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg'" />
                    <div class="hero-host-info">
                        Hosted by <a href="/User/@Model.Owner?.Username">@Model.Owner?.Username</a>
                    </div>
                </div>

                @* LastOrDefault is mostly be the country, So this mean we trim only country *@
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <div class="hero-tag">
                        <i class="fas fa-map-marker-alt"></i>
                        @(Model.Location.Split(',').LastOrDefault()?.Trim() ?? Model.Location)
                    </div>
                }
                <div class="hero-tag">
                    <i class="fas fa-users"></i> @Model.Participants.Count / @Model.MaxParticitpant Joined
                </div>
                <div class="hero-tag hero-tag-free">Free</div>
                @{
                    string statusClass = Model.ComputedStatus switch
                    {
                        "open" => "status-open",
                        "ongoing" => "status-ongoing",
                        "closed" => "status-closed",
                        "ended" => "status-ended",
                        _ => "status-open"
                    };
                }
                <div class="hero-tag @statusClass">
                    <i class="fas fa-circle" style="font-size:8px;"></i> @Model.ComputedStatus
                </div>
                @if (now >= Model.EventStart && now <= Model.EventStop)
                {
                    <div class="attendance-public">
                        <i class="fas fa-clipboard-check" style="color:#4ade80; font-size:13px;"></i>
                        <span class="attendance-public-text">@ViewBag.AttendCount people attended</span>
                        <div class="attendance-public-bar">
                            @{
                                int attendCount = (int)(ViewBag.AttendCount ?? 0);
                            }
                            <div class="attendance-public-fill"
                                 style="width: @(Model.MaxParticitpant > 0
                                          ? ((double)attendCount / Model.MaxParticitpant * 100)
                                          : 0)%">
                            </div>
                        </div>
                        <span style="font-size:12px; color:var(--text-muted);">of @Model.MaxParticitpant</span>
                    </div>   
                }
            </div>

        </div>
    </div>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="Container">
        <div class="devider">

            <!-- LEFT SIDE -->
            <div class="detail-part">

                <!-- Details Section -->
                <section class="section-gap">
                    <h2>Details</h2>
                    <p class="detail" id="detailText">@Model.Description</p>
                    <button id="readMoreBtn">Read More ↓</button>
                </section>

                <!-- Photos Section -->
                <section class="section-gap">
                    <h2>Photos <span class="photo-count">0</span></h2>
                    <div class="empty-state">
                        <i class="far fa-image"></i>
                        <p>No photos for now! You'll see<br>them here once they're added.</p>
                    </div>
                    <div class="carousel-wrapper">
                        <button class="arrow left-arrow" onclick="slide(-1)">&#8592;</button>
                        <div class="carousel-track" id="carouselTrack"></div>
                        <button class="arrow right-arrow" onclick="slide(1)">&#8594;</button>
                    </div>
                </section>

                <section class="section-gap">
                    <h2>Location</h2>
                    <div id="map" style="height:300px; border-radius:16px; border:1px solid var(--border);"></div>
                </section>

                <!-- Event Chat Section (Only for participants or host) -->
                @if (ViewBag.IsJoined == true || (ViewBag.IsLoggedIn == true && Model.OwnerId == ViewBag.UserId))
                {
                    <section class="section-gap">
                        <h2>Event Chat</h2>
                        <div class="chat-container">
                            <div class="chat-messages" id="chatMessages">
                                <!-- Messages will be rendered here dynamically -->
                            </div>
                            <div class="chat-input-area">
                                <input type="text" id="chatInput" placeholder="Type a message..." maxlength="255" />
                                <button id="sendChatBtn"><i class="fas fa-paper-plane"></i></button>
                            </div>
                        </div>
                    </section>
                }
                
                <section>
                    
                    @if (Model.Owner?.Uid == ViewBag.UserId && now >= Model.EventStart && now <= Model.EventStop)
                    {
                        <h2>Attendance</h2>
                        <div class="attendance-host">
                            <div class="attend-header">
                                <div class="attend-header-left">
                                    <div class="attend-header-icon">
                                        <i class="fas fa-clipboard-check"></i>
                                    </div>
                                    <div>
                                        <div class="attend-header-title">Who Attended</div>
                                        <div class="attend-header-sub">Scanned during event</div>
                                    </div>
                                </div>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <div class="attend-count-badge">@ViewBag.AttendCount attended</div>
                                    <div class="attend-count-badge" style="background:rgba(248,113,113,0.12); border-color:rgba(248,113,113,0.25); color:#f87171;">
                                        @(Model.Participants.Count - (int)(ViewBag.AttendCount ?? 0))
                                    </div>
                                </div>
                            </div>

                            <div class="attend-divider"></div>

                            @if (ViewBag.AttendList != null && ((List<testforproject.Models.User>)ViewBag.AttendList).Any())
                            {
                                <div class="attend-scroll-wrap">
                                    <div class="attend-scroll" id="attendScroll">
                                        @foreach (var user in (List<testforproject.Models.User>)ViewBag.AttendList)
                                        {
                                            <div class="attend-card">
                                                <div class="attend-avatar-wrap">
                                                    <img class="attend-avatar"
                                                         src="@(!string.IsNullOrEmpty(user.ProfilePictureSrc)
                                                                                                        ? user.ProfilePictureSrc
                                                                                                        : "https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg")"
                                                         onerror="this.src='https://wallpapers.com/images/hd/anonymous-profile-icon-5xbeg73qv03oqvc5.jpg'" />
                                                    <div class="attend-check"><i class="fas fa-check"></i></div>
                                                </div>
                                                <div class="attend-name">@user.Username</div>
                                                <div class="attend-time">
                                                    @(ViewBag.AttendTimes != null &&
                                                        ((Dictionary<int, DateTimeOffset>)ViewBag.AttendTimes).ContainsKey(user.Uid)
                                                        ? ((Dictionary<int, DateTimeOffset>)ViewBag.AttendTimes)[user.Uid].ToString("hh:mm tt")
                                                        : "")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="attend-footer">
                                    <div class="attend-footer-hint">
                                        <i class="fas fa-hand-pointer" style="font-size:10px;"></i>
                                        swipe or use arrows
                                    </div>
                                    <div class="attend-arrows">
                                        <button class="attend-arrow-btn" onclick="scrollAttend(-1)">◀</button>
                                        <button class="attend-arrow-btn" onclick="scrollAttend(1)">▶</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="attend-empty">
                                    <i class="fas fa-user-clock"></i>
                                    <span>No one has scanned yet</span>
                                </div>
                            }
                        </div>
                    }
                </section>


            </div>

            <!-- RIGHT SIDE -->
            <div class="right-part">

                <!-- Event Image -->
                <div class="img-part">
                    <div class="transparent-img"></div>
                    <div class="main-img">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" />
                        }
                        else
                        {
                            <div class="main-img-empty">
                                <span>No Image</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Reserve Card -->
                <div class="reserve-card">

                    <div class="in-card">
                        <div class="in-card-icon"><i class="far fa-calendar-alt"></i></div>
                        <div>
                            <div class="in-card-label">Event Date</div>
                            <div class="in-card-value">@Model.EventStart.ToString("dddd, MMM dd · hh:mm tt")</div>
                            <div class="in-card-sub">Duration: @(Model.EventStop - Model.EventStart)</div>
                        </div>
                    </div>
                    <div class="card-divider"></div>

                    <div class="in-card">
                        <div class="in-card-icon"><i class="far fa-clock"></i></div>
                        <div>
                            <div class="in-card-label">Registration Closes</div>
                            <div class="in-card-value">@Model.ExpiredDate.ToString("MMM dd, yyyy · hh:mm tt")</div>
                            <div class="in-card-sub" id="remainTime"></div>
                        </div>
                    </div>
                    <div class="card-divider"></div>

                    <div class="in-card">
                        <div class="in-card-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <div class="in-card-label">Location</div>
                            <div class="in-card-value">@Model.Location</div>
                        </div>
                    </div>
                    <div class="card-divider"></div>

                    <div class="in-card">
                        <div class="in-card-icon"><i class="fas fa-users"></i></div>
                        <div style="width: 100%;">
                            <div class="in-card-label">Participants</div>
                            <div class="in-card-value">@Model.Participants.Count / @Model.MaxParticitpant Joined</div>
                            @* <div class="in-card-sub">@(Model.MaxParticitpant - Model.Participants.Count) spots remaining</div>
                            <div class="participant-bar">
                                <div class="participant-bar-fill"
                                     style="width: @(((double)Model.Participants.Count / Model.MaxParticitpant) * 100)%">
                                </div>
                            </div> *@
                        </div>
                    </div>

                    @if (ViewBag.IsLoggedIn == true && Model.Owner?.Uid != ViewBag.UserId)
                    {
                        if (ViewBag.IsJoined == true && Model.status == "closed")
                        {
                            <a href="@Url.Action("EventScore", "Event", new { id = Model.Eid })" style="text-decoration:none;">
                                <button class="join_btn" style="background-color: #ffd700; color: #000; box-shadow: 0 4px 12px rgba(255, 215, 0, 0.3);">
                                    <i class="fas fa-star"></i> Rate Event
                                </button>
                            </a>
                        }
                        else if (ViewBag.IsJoined == true)
                        {
                            <button class="join_btn" disabled>
                                Already Joined
                            </button>
                        }
                        else if (Model.ComputedStatus == "ended")
                        {
                            <button class="join_btn join_btn--ended" disabled>
                                Event Ended
                            </button>
                        }
                        else if (Model.ComputedStatus == "closed" || Model.ComputedStatus == "ongoing")
                        {
                            <button class="join_btn join_btn--full" disabled>
                                Registration Closed
                            </button>
                        }
                        else
                        {
                            <button class="join_btn" onclick="joinEvent(@Model.Eid)">
                                Join Event
                            </button>
                        }
                    }
                    else if (ViewBag.IsLoggedIn != true)
                    {
                        <a href="@Url.Action("Login", "Account")">
                            <button class="join_btn">Login to Join</button>
                        </a>      
                    }
                    @* Qr Code *@
                    @if (Model.Owner?.Uid == ViewBag.UserId && now >= Model.EventStart && now <= Model.EventStop)
                    {
                        <div class="qr-section">
                            <div class="qr-label">📱 Attendance QR</div>
                            <img src="/Event/QRCode/@Model.Eid" class="qr-img" />
                            <div class="qr-sub">ให้ผู้เข้าร่วม scan เพื่อยืนยันการเข้าร่วม</div>
                        </div>
                    }
                </div>
            </div>
            <div id="toast" class="toast"></div>
        </div>
    </div>

    <script>
        const mockPhotos = @Html.Raw(Json.Serialize(
                        new[] { Model.ImageUrl }.Where(x => !string.IsNullOrEmpty(x))
                ));
        const eventLocation = "@Model.Location";
        const expiredDateStr = "@Model.ExpiredDate.ToString("o")";
    </script>
    <script src="~/js/Event/EventDetails.js"></script>
    <script>
        // Mobile nav hamburger toggle
        (function () {
            var btn = document.getElementById('navHamburger');
            var nav = document.querySelector('.navbar');
            if (btn && nav) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    nav.classList.toggle('nav-open');
                });
                document.addEventListener('click', function () {
                    nav.classList.remove('nav-open');
                });
            }
        })();
    </script>

    @if (ViewBag.IsJoined == true || (ViewBag.IsLoggedIn == true && Model.OwnerId == ViewBag.UserId))
    {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>

        document.addEventListener('DOMContentLoaded', () => {
            const eventId = @Model.Eid;
            const chatMessagesContent = document.getElementById('chatMessages');
            const chatInput = document.getElementById('chatInput');
            const sendChatBtn = document.getElementById('sendChatBtn');
            let lastMessageCount = 0;

            async function fetchMessages() {
                try {
                    const response = await fetch(`/api/ChatApi/${eventId}`);
                    if (!response.ok) return;
                    const messages = await response.json();

                    if (messages.length !== lastMessageCount) {
                        chatMessagesContent.innerHTML = '';
                        messages.forEach(msg => {
                            const isSelf = msg.senderName === 'You';
                            const timeString = new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                            
                            const msgHtml = `
                                <div class="chat-message ${isSelf ? 'self' : 'other'}">
                                    ${!isSelf ? `<div class="chat-sender">${msg.senderName}</div>` : ''}
                                    <div class="chat-bubble">${msg.message}</div>
                                    <div class="chat-time">${timeString}</div>
                                </div>
                            `;
                            chatMessagesContent.insertAdjacentHTML('beforeend', msgHtml);
                        });
                        
                        // Auto scroll to bottom
                        chatMessagesContent.scrollTop = chatMessagesContent.scrollHeight;
                        lastMessageCount = messages.length;
                    }
                } catch (err) {
                    console.error("Failed to load chat", err);
                }
            }

            async function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;

                chatInput.disabled = true;
                sendChatBtn.disabled = true;

                try {
                    const userId = @(ViewBag.UserId ?? "0"); // Supply the acting user ID
                    await connection.invoke("SendMessage", eventId, text, userId);
                    chatInput.value = '';
                } catch (err) {
                    console.error("SignalR SendMessage Error: ", err);
                } finally {
                    chatInput.disabled = false;
                    sendChatBtn.disabled = false;
                    chatInput.focus();
                }
            }

            sendChatBtn.addEventListener('click', sendMessage);
            chatInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') sendMessage();
            });

            // SignalR Connection Setup
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            connection.on("ReceiveNewMessage", () => {
                fetchMessages(); // Immediately pull new messages
            });

            async function startSignalR() {
                try {
                    await connection.start();
                    console.log("SignalR Connected.");
                    // Join the specific event group
                    await connection.invoke("JoinEventGroup", eventId.toString());
                } catch (err) {
                    console.error("SignalR Connection Error: ", err);
                    setTimeout(startSignalR, 5000);
                }
            }

            // Initial messages load and connect
            fetchMessages();
            startSignalR();
        });
    </script>
    }

</body>
</html>



<!--
    1.event name
    2.status
    3.categories
    4.description
    5.start/close time
    6.duration
    7.location
    8.max participant (do a progression bar)
    9.owner profile + name
    10.requirement
-->
